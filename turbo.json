{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.example"],
  "globalEnv": [
    "CI",
    "PORT",
    "APP_PUBLIC_URL",
    "DATABASE_URL",
    "NODE_ENV",
    "CORS_ORIGINS",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "REDIS_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WEB_STUDENT_URL",
    "NEXT_PUBLIC_WEB_SALES_URL",
    "NEXT_PUBLIC_TENANT_ID",
    "NEXT_PUBLIC_NOTIFICATION_STREAM_URL",
    "AUTH_COOKIE_SAME_SITE",
    "AUTH_COOKIE_DOMAIN",
    "TRUST_PROXY",
    "ALLOW_TENANT_HEADER_IN_PRODUCTION",
    "MCP_ENABLED",
    "MCP_API_KEY",
    "MCP_TENANT_ID",
    "AI_PROVIDER",
    "AI_ENDPOINT_URL",
    "AI_API_KEY",
    "AI_MODEL",
    "AI_TIMEOUT_MS",
    "AI_MAX_OUTPUT_TOKENS",
    "AI_TEMPERATURE",
    "GROQ_API_KEY",
    "GROQ_BASE_URL",
    "GROQ_MODEL",
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "WEB_STUDENT_BASE_URL",
    "SUPER_PORTAL_BASE_URL",
    "STAGING_STUDENT_EMAIL",
    "STAGING_STUDENT_PASSWORD",
    "STAGING_SUPER_EMAIL",
    "STAGING_SUPER_PASSWORD",
    "npm_package_version"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "prisma/**",
        "next.config.*",
        "next-env.d.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".turbo/**"]
    },
    "@repo/database#build": {
      "dependsOn": [],
      "inputs": ["prisma/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**", ".prisma/client/**"]
    },
    "lint": {
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/.eslintrc*"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "inputs": ["**/*.ts", "**/*.tsx"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "next-env.d.ts", "next.config.*", "tsconfig.json"],
      "outputs": []
    }
  }
}
