{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.example"],
  "globalEnv": [
    "CI",
    "PORT",
    "APP_PUBLIC_URL",
    "DATABASE_URL",
    "NODE_ENV",
    "CORS_ORIGINS",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "REDIS_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WEB_STUDENT_URL",
    "NEXT_PUBLIC_TENANT_ID",
    "AUTH_COOKIE_SAME_SITE",
    "AUTH_COOKIE_DOMAIN",
    "TRUST_PROXY",
    "ALLOW_TENANT_HEADER_IN_PRODUCTION",
    "MCP_ENABLED",
    "MCP_API_KEY",
    "MCP_TENANT_ID",
    "npm_package_version"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "prisma/**", "next.config.*", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".turbo/**"]
    },
    "@repo/database#build": {
      "dependsOn": [],
      "inputs": ["prisma/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**", ".prisma/client/**"]
    },
    "lint": {
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/.eslintrc*"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "inputs": ["**/*.ts", "**/*.tsx"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "next.config.*", "tsconfig.json"],
      "outputs": []
    }
  }
}
