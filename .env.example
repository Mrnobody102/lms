# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5433/lms_platform?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="lms_platform"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
THROTTLER_TTL=60000
THROTTLER_LIMIT=100

# Security
JWT_SECRET="your_secure_jwt_secret_key_that_is_at_least_32_chars"
JWT_EXPIRES_IN="7d"
JWT_RESET_SECRET="your_secure_password_reset_secret_key"
JWT_REFRESH_EXPIRES_IN="30d"

# Mail Configuration
MAIL_ENABLED="false"
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="user@example.com"
MAIL_PASS="password"
MAIL_FROM="LMS Platform <noreply@example.com>"

# Application Settings
PORT=4000
APP_PUBLIC_URL="http://localhost:4000"
NODE_ENV=development
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WEB_STUDENT_URL="http://localhost:3100"
NEXT_PUBLIC_WEB_SALES_URL="http://localhost:3103"
NEXT_PUBLIC_TENANT_ID="replace_with_tenant_id_for_this_frontend"
CORS_ORIGINS="http://localhost:3100,http://localhost:3101,http://localhost:3102,http://localhost:3103"
TRUST_PROXY="false"
# Set to 'false' in production — tenant must be resolved from origin/domain, not client-supplied header
ALLOW_TENANT_HEADER_IN_PRODUCTION="false"
# Cookie SameSite policy:
#   'lax'    — safe default. Use when frontend and API are on the same domain or subdomains (e.g. hoc.example.com + api.example.com).
#              Must also set AUTH_COOKIE_DOMAIN to the shared root domain (e.g. .example.com).
#   'none'   — required when frontend and API are on completely different domains (cross-origin).
#              Requires HTTPS (Secure flag is forced automatically).
#              NOTE: Safari iOS blocks third-party cookies; same-site deployment is strongly preferred.
#   'strict' — most restrictive, may break OAuth redirects.
AUTH_COOKIE_SAME_SITE="lax"
# Set to your root domain to share cookie across subdomains, e.g. .example.com
# Leave empty for localhost/single-domain setups
AUTH_COOKIE_DOMAIN=""

# Google Identity Services login
# Use the Web application OAuth client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_IDS=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# AI Configuration
# Set AI_PROVIDER="groq" and GROQ_API_KEY in api-server production env to enable Groq.
AI_PROVIDER="off"
AI_ENDPOINT_URL="https://ai-gateway.example.com/evaluate"
AI_API_KEY="replace_later"
GOOGLE_GENERATIVE_AI_API_KEY=""
AI_MODEL="default"
GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="llama-3.3-70b-versatile"
AI_TIMEOUT_MS=15000
AI_MAX_OUTPUT_TOKENS=512
AI_TEMPERATURE=0.2

# MCP Configuration
MCP_ENABLED="false"
MCP_API_KEY="replace_with_at_least_32_random_characters"
MCP_ALLOW_QUERY_API_KEY="false"
MCP_PROJECT_ROOT=""
MCP_TENANT_ID=""
