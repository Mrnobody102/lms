# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5433/lms_platform?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="lms_platform"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
THROTTLER_TTL=60000
THROTTLER_LIMIT=100

# Security
JWT_SECRET="your_secure_jwt_secret_key_that_is_at_least_32_chars"
JWT_EXPIRES_IN="7d"
JWT_RESET_SECRET="your_secure_password_reset_secret_key"
JWT_REFRESH_EXPIRES_IN="30d"

# Mail Configuration
MAIL_ENABLED="false"
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="user@example.com"
MAIL_PASS="password"
MAIL_FROM="LMS Platform <noreply@example.com>"

# Application Settings
PORT=4000
APP_PUBLIC_URL="http://localhost:4000"
NODE_ENV=development
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WEB_STUDENT_URL="http://localhost:3000"
NEXT_PUBLIC_TENANT_ID="replace_with_tenant_id_for_this_frontend"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"
TRUST_PROXY="false"
ALLOW_TENANT_HEADER_IN_PRODUCTION="false"
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_DOMAIN=""

# Google Identity Services login
# Use the Web application OAuth client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_IDS=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# AI Configuration
# Keep off until API endpoint/key is ready.
AI_PROVIDER="off"
AI_ENDPOINT_URL="https://ai-gateway.example.com/evaluate"
AI_API_KEY="replace_later"
AI_MODEL="default"
AI_TIMEOUT_MS=15000
AI_MAX_OUTPUT_TOKENS=512
AI_TEMPERATURE=0.2

# MCP Configuration
MCP_ENABLED="false"
MCP_API_KEY="replace_with_at_least_32_random_characters"
MCP_ALLOW_QUERY_API_KEY="false"
MCP_PROJECT_ROOT=""
MCP_TENANT_ID=""
