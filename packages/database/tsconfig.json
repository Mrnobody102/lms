{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "isolatedModules": false
  },
  "include": ["src/**/*.ts", "index.ts"],
  "exclude": ["node_modules", "prisma"]
}
