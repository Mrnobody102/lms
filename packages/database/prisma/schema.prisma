generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN    // Quản trị toàn hệ thống (là bạn)
  ADMIN          // Chủ trung tâm
  INSTRUCTOR     // Giảng viên
  STUDENT        // Học sinh
}

enum LessonType {
  video
  text
  quiz
}

enum ProgressStatus {
  IN_PROGRESS
  COMPLETED
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // Ví dụ: "trung-tam-a"
  domain      String?  @unique // Custom domain sau này
  settings    Json     // Lưu logo, màu sắc, config
  users       User[]
  courses     Course[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([isActive])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  fullName    String
  phoneNumber String?
  avatarUrl   String?
  role        Role     @default(STUDENT)
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  progress    UserLessonProgress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, role])
  @@index([tenantId, isActive])
}

model Course {
  id        String   @id @default(uuid())
  title     String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  lessons   Lesson[]
}

model Lesson {
  id        String     @id @default(uuid())
  title     String
  type      LessonType @default(text)
  content   String?    // Nội dung bài học (HTML/Markdown)
  videoUrl  String?    // Link video bài giảng
  duration  Int        @default(10) // Thời lượng dự kiến (phút)
  quiz      Json?      // Nội dung quiz (nếu type là quiz)
  order     Int        @default(0) // Thứ tự bài học trong khóa học
  courseId  String
  course    Course     @relation(fields: [courseId], references: [id])
  progress  UserLessonProgress[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([courseId])
}

model UserLessonProgress {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  lessonId  String
  lesson    Lesson         @relation(fields: [lessonId], references: [id])
  status    ProgressStatus @default(IN_PROGRESS)
  updatedAt DateTime       @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}
