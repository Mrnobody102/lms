  expectedText       String?
  overallScore       Int?
  fluencyScore       Int?
  accuracyScore      Int?
  completenessScore  Int?
  wordScores         Json?
  provider           String?
  rawProviderPayload Json?
  errorMessage       String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, sessionId])
  @@index([tenantId, status, createdAt])
}

model Notification {
