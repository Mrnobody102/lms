model PronunciationAssessment {
  id                 String                        @id @default(uuid())
  tenantId           String
  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId          String
  session            RoleplaySession               @relation(fields: [sessionId, tenantId], references: [id, tenantId], onDelete: Cascade)
