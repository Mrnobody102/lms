model MarketplaceItem {
  id              String                  @id @default(uuid())
  ownerTenantId   String
  ownerTenant     Tenant                  @relation("MarketplaceItemOwnerTenant", fields: [ownerTenantId], references: [id], onDelete: Cascade)
  resourceType    MarketplaceResourceType
  resourceId      String
  title           String
  description     String?
  pricingModel    MarketplacePricingModel @default(FREE)
  priceCents      Int                     @default(0)
  currency        String                  @default("USD")
  revenueShareBps Int                     @default(7000)
  isPublished     Boolean                 @default(false)
  publishedAt     DateTime?
  metadata        Json?
  subscriptions   ResourceSubscription[]
  usageEvents     MarketplaceUsageEvent[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([ownerTenantId, resourceType, isPublished])
  @@index([resourceType, resourceId])
  @@index([isPublished, publishedAt])
}

model ResourceSubscription {
  id                 String                     @id @default(uuid())
  marketplaceItemId  String
  marketplaceItem    MarketplaceItem            @relation(fields: [marketplaceItemId], references: [id], onDelete: Cascade)
  providerTenantId   String
  providerTenant     Tenant                     @relation("MarketplaceProviderTenant", fields: [providerTenantId], references: [id], onDelete: Cascade)
  subscriberTenantId String
  subscriberTenant   Tenant                     @relation("MarketplaceSubscriberTenant", fields: [subscriberTenantId], references: [id], onDelete: Cascade)
  status             ResourceSubscriptionStatus @default(ACTIVE)
  startsAt           DateTime                   @default(now())
  endsAt             DateTime?
  purchasedAt        DateTime                   @default(now())
  priceCents         Int                        @default(0)
  currency           String                     @default("USD")
  metadata           Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@unique([marketplaceItemId, subscriberTenantId])
  @@index([providerTenantId, status])
  @@index([subscriberTenantId, status])
  @@index([endsAt])
}

model MarketplaceUsageEvent {
  id                 String                    @id @default(uuid())
  marketplaceItemId  String
  marketplaceItem    MarketplaceItem           @relation(fields: [marketplaceItemId], references: [id], onDelete: Cascade)
  providerTenantId   String
  providerTenant     Tenant                    @relation("MarketplaceUsageProviderTenant", fields: [providerTenantId], references: [id], onDelete: Cascade)
  subscriberTenantId String
  subscriberTenant   Tenant                    @relation("MarketplaceUsageSubscriberTenant", fields: [subscriberTenantId], references: [id], onDelete: Cascade)
  userId             String?
  resourceType       MarketplaceResourceType
  resourceId         String
  eventType          MarketplaceUsageEventType
  quantity           Int                       @default(1)
  seconds            Int?
  revenueShareCents  Int                       @default(0)
  occurredAt         DateTime                  @default(now())
  createdAt          DateTime                  @default(now())

  @@index([marketplaceItemId, occurredAt])
  @@index([providerTenantId, occurredAt])
  @@index([subscriberTenantId, occurredAt])
  @@index([eventType, occurredAt])
}

model VideoEngagementEvent {
