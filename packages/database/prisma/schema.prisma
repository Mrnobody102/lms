generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN    // Quản trị toàn hệ thống (là bạn)
  ADMIN          // Chủ trung tâm
  INSTRUCTOR     // Giảng viên
  STUDENT        // Học sinh
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // Ví dụ: "trung-tam-a"
  domain      String?  @unique // Custom domain sau này
  settings    Json     // Lưu logo, màu sắc, config
  users       User[]
  courses     Course[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([isActive])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  fullName    String
  phoneNumber String?
  avatarUrl   String?
  role        Role     @default(STUDENT)
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, role])
  @@index([tenantId, isActive])
}

model Course {
  id        String   @id @default(uuid())
  title     String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}
