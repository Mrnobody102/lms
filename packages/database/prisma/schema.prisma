generator client {
  provider = "prisma-client-js"
  output   = "../.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN // Quản trị toàn hệ thống (là bạn)
  ADMIN // Chủ trung tâm
  INSTRUCTOR // Giảng viên
  STUDENT // Học sinh
}

enum LessonType {
  video
  text
  quiz
  simulation
  micro_card
}

enum ProgressStatus {
  IN_PROGRESS
  COMPLETED
}

enum EnrollmentStatus {
  ACTIVE
  REVOKED
}

enum LearningActivityType {
  LESSON_OPENED
  LESSON_COMPLETED
}

enum PracticeQuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  AI_EVALUATED_AUDIO
  AI_EVALUATED_TEXT
  MATCHING
  ORDERING
}

enum PracticeAttemptStatus {
  SUBMITTED
}

enum ExamQuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  AI_EVALUATED_AUDIO
  AI_EVALUATED_TEXT
  MATCHING
  ORDERING
}

enum ExamAttemptStatus {
  STARTED
  SUBMITTED
}

model Tenant {
  id               String                @id @default(uuid())
  name             String
  slug             String                @unique // Ví dụ: "trung-tam-a"
  domain           String?               @unique // Custom domain sau này
  settings         Json // Lưu logo, màu sắc, config
  users            User[]
  courses          Course[]
  units            CourseUnit[]
  lessons          Lesson[]
  enrollments      CourseEnrollment[]
  activities       LearningActivity[]
  questions        PracticeQuestion[]
  exerciseSets     PracticeExerciseSet[]
  practiceAttempts PracticeAttempt[]
  exams            Exam[]
  examAttempts     ExamAttempt[]
  activationCodes  ActivationCode[]
  redemptions      ActivationRedemption[]
  programs         Program[]
  levels           Level[]
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @default(now()) @updatedAt

  @@index([isActive])
}

model User {
  id               String               @id @default(uuid())
  email            String
  password         String
  fullName         String
  phoneNumber      String?
  avatarUrl        String?
  role             Role                 @default(STUDENT)
  isActive         Boolean              @default(true)
  deletedAt        DateTime?
  tokenVersion     Int                  @default(0)
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  failedLoginAttempts    Int               @default(0)
  lockoutUntil           DateTime?
  tenantId         String
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progress         UserLessonProgress[]
  enrollments      CourseEnrollment[]
  activities       LearningActivity[]
  practiceAttempts PracticeAttempt[]
  examAttempts     ExamAttempt[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  redemptions      ActivationRedemption[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([tenantId, email])
  @@unique([id, tenantId])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId  String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  action    String   // e.g., 'LOGIN', 'PASSWORD_CHANGE', 'PROFILE_UPDATE'
  status    String   // 'SUCCESS', 'FAILURE'
  ipAddress String?
  userAgent String?
  metadata  Json?    // Any extra context
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
  @@index([action])
  @@index([createdAt])
}

model Course {
  id               String                @id @default(uuid())
  title            String
  slug             String? // SEO-friendly slug
  description      String?
  isActive         Boolean               @default(true)
  deletedAt        DateTime?
  tenantId         String
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  levelId          String?
  level            Level?                @relation(fields: [levelId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  units            CourseUnit[]
  lessons          Lesson[]
  enrollments      CourseEnrollment[]
  activities       LearningActivity[]
  questions        PracticeQuestion[]
  exerciseSets     PracticeExerciseSet[]
  practiceAttempts PracticeAttempt[]
  exams            Exam[]
  examAttempts     ExamAttempt[]
  totalDuration    Int                   @default(0)
  aiSettings       Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  activationCodes  ActivationCode[]

  @@unique([tenantId, slug])
  @@unique([id, tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
  @@index([levelId])
}

model Program {
  id               String      @id @default(uuid())
  title            String
  slug             String?
  description      String?
  isActive         Boolean     @default(true)
  deletedAt        DateTime?
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  levels           Level[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, isActive, deletedAt])
}

model Level {
  id               String      @id @default(uuid())
  title            String
  description      String?
  order            Int         @default(0)
  isActive         Boolean     @default(true)
  deletedAt        DateTime?
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programId        String
  program          Program     @relation(fields: [programId, tenantId], references: [id, tenantId], onDelete: Cascade)
  courses          Course[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, programId, deletedAt])
  @@index([programId, order])
}

model CourseUnit {
  id           String                @id @default(uuid())
  title        String
  description  String?
  order        Int                   @default(0)
  deletedAt    DateTime?
  tenantId     String
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course                @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  lessons      Lesson[]
  questions    PracticeQuestion[]
  exerciseSets PracticeExerciseSet[]
  exams        Exam[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, courseId, deletedAt])
  @@index([courseId, order])
}

model Lesson {
  id         String               @id @default(uuid())
  title      String
  type       LessonType           @default(text)
  content    String? // Nội dung bài học (HTML/Markdown)
  videoUrl   String? // Link video bài giảng
  duration   Int                  @default(10) // Thời lượng dự kiến (phút)
  quiz       Json? // Nội dung quiz (nếu type là quiz)
  aiPrompt   String?
  order      Int                  @default(0) // Thứ tự bài học trong khóa học
  deletedAt  DateTime?
  tenantId   String
  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course               @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId     String?
  unit       CourseUnit?          @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  progress   UserLessonProgress[]
  activities LearningActivity[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([id, tenantId])
  @@index([courseId])
  @@index([unitId])
  @@index([tenantId, type])
  @@index([tenantId, deletedAt])
}

model UserLessonProgress {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  lessonId  String
  lesson    Lesson         @relation(fields: [lessonId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId  String // Denormalized tenantId for row-level isolation
  status    ProgressStatus @default(IN_PROGRESS)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([tenantId])
}

model CourseEnrollment {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  courseId     String
  course       Course           @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now())
  unenrolledAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, courseId])
  @@index([tenantId, status])
  @@index([courseId])
  @@index([userId])
}

model LearningActivity {
  id               String               @id @default(uuid())
  userId           String
  user             User                 @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId         String
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId         String
  course           Course               @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  lessonId         String
  lesson           Lesson               @relation(fields: [lessonId, tenantId], references: [id, tenantId], onDelete: Cascade)
  type             LearningActivityType
  timeSpentSeconds Int?
  occurredAt       DateTime             @default(now())

  @@index([userId, occurredAt])
  @@index([tenantId, occurredAt])
  @@index([courseId, occurredAt])
  @@index([lessonId, occurredAt])
  @@index([userId, lessonId, type, occurredAt])
}

model PracticeQuestion {
  id            String                        @id @default(uuid())
  tenantId      String
  tenant        Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course                        @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId        String?
  unit          CourseUnit?                   @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  type          PracticeQuestionType          @default(MULTIPLE_CHOICE)
  prompt        String
  options       Json?
  correctAnswer Json
  explanation   String?
  skillTags     String[]
  deletedAt     DateTime?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt
  exerciseLinks PracticeExerciseSetQuestion[]
  answers       PracticeAnswer[]

  @@unique([id, tenantId])
  @@index([tenantId, courseId, deletedAt])
  @@index([unitId])
  @@index([type])
}

model PracticeExerciseSet {
  id          String                        @id @default(uuid())
  tenantId    String
  tenant      Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course                        @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId      String?
  unit        CourseUnit?                   @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  title       String
  description String?
  isPublished Boolean                       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt
  questions   PracticeExerciseSetQuestion[]
  attempts    PracticeAttempt[]

  @@unique([id, tenantId])
  @@index([tenantId, courseId, isPublished, deletedAt])
  @@index([unitId])
}

model PracticeExerciseSetQuestion {
  id            String              @id @default(uuid())
  tenantId      String
  exerciseSetId String
  exerciseSet   PracticeExerciseSet @relation(fields: [exerciseSetId, tenantId], references: [id, tenantId], onDelete: Cascade)
  questionId    String
  question      PracticeQuestion    @relation(fields: [questionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  order         Int                 @default(0)
  createdAt     DateTime            @default(now())

  @@unique([exerciseSetId, questionId])
  @@index([tenantId, exerciseSetId, order])
  @@index([questionId])
}

model PracticeAttempt {
  id            String                @id @default(uuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User                  @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  courseId      String
  course        Course                @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  exerciseSetId String
  exerciseSet   PracticeExerciseSet   @relation(fields: [exerciseSetId, tenantId], references: [id, tenantId], onDelete: Cascade)
  status        PracticeAttemptStatus @default(SUBMITTED)
  score         Int
  totalPoints   Int
  submittedAt   DateTime              @default(now())
  createdAt     DateTime              @default(now())
  answers       PracticeAnswer[]

  @@unique([id, tenantId])
  @@index([tenantId, userId, submittedAt])
  @@index([exerciseSetId, submittedAt])
  @@index([courseId, submittedAt])
}

model PracticeAnswer {
  id         String           @id @default(uuid())
  tenantId   String
  attemptId  String
  attempt    PracticeAttempt  @relation(fields: [attemptId, tenantId], references: [id, tenantId], onDelete: Cascade)
  questionId String
  question   PracticeQuestion @relation(fields: [questionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  answer     Json
  isCorrect  Boolean
  aiFeedback Json?
  createdAt  DateTime         @default(now())

  @@unique([attemptId, questionId])
  @@index([tenantId, attemptId])
  @@index([questionId])
}

model Exam {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course        @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId          String?
  unit            CourseUnit?   @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  title           String
  description     String?
  durationMinutes Int           @default(30)
  passingScore    Int?
  isPublished     Boolean       @default(false)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sections        ExamSection[]
  attempts        ExamAttempt[]

  @@unique([id, tenantId])
  @@index([tenantId, courseId, isPublished, deletedAt])
  @@index([unitId])
}

model ExamSection {
  id        String         @id @default(uuid())
  tenantId  String
  examId    String
  exam      Exam           @relation(fields: [examId, tenantId], references: [id, tenantId], onDelete: Cascade)
  title     String
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  questions ExamQuestion[]

  @@unique([id, tenantId])
  @@index([tenantId, examId, order])
}

model ExamQuestion {
  id            String           @id @default(uuid())
  tenantId      String
  sectionId     String
  section       ExamSection      @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  type          ExamQuestionType @default(MULTIPLE_CHOICE)
  prompt        String
  options       Json?
  correctAnswer Json
  explanation   String?
  points        Int              @default(1)
  skillTags     String[]
  order         Int              @default(0)
  createdAt     DateTime         @default(now())
  answers       ExamAnswer[]

  @@unique([id, tenantId])
  @@index([tenantId, sectionId, order])
  @@index([type])
}

model ExamAttempt {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  courseId    String
  course      Course            @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  examId      String
  exam        Exam              @relation(fields: [examId, tenantId], references: [id, tenantId], onDelete: Cascade)
  status      ExamAttemptStatus @default(STARTED)
  score       Int               @default(0)
  totalPoints Int               @default(0)
  startedAt   DateTime          @default(now())
  submittedAt DateTime?
  createdAt   DateTime          @default(now())
  answers     ExamAnswer[]

  @@unique([id, tenantId])
  @@index([tenantId, userId, startedAt])
  @@index([examId, startedAt])
  @@index([courseId, startedAt])
}

model ExamAnswer {
  id            String       @id @default(uuid())
  tenantId      String
  attemptId     String
  attempt       ExamAttempt  @relation(fields: [attemptId, tenantId], references: [id, tenantId], onDelete: Cascade)
  questionId    String
  question      ExamQuestion @relation(fields: [questionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  answer        Json
  isCorrect     Boolean
  pointsAwarded Int          @default(0)
  aiFeedback    Json?
  createdAt     DateTime     @default(now())

  @@unique([attemptId, questionId])
  @@index([tenantId, attemptId])
  @@index([questionId])
}

model ActivationCode {
  id               String                 @id @default(uuid())
  tenantId         String
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code             String
  description      String?
  maxUses          Int                    @default(1)
  usedCount        Int                    @default(0)
  expiresAt        DateTime?
  courseId         String?
  course           Course?                @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  isActive         Boolean                @default(true)
  deletedAt        DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  redemptions      ActivationRedemption[]

  @@unique([id, tenantId])
  @@unique([tenantId, code])
  @@index([tenantId, isActive, deletedAt])
  @@index([courseId])
}

model ActivationRedemption {
  id               String         @id @default(uuid())
  tenantId         String
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activationCodeId String
  activationCode   ActivationCode @relation(fields: [activationCodeId, tenantId], references: [id, tenantId], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  redeemedAt       DateTime       @default(now())

  @@index([tenantId, userId])
  @@index([activationCodeId])
}
