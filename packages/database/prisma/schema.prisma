enum ReviewCardSource {
  PRACTICE_QUESTION
  EXAM_QUESTION
  CUSTOM
}

enum ReviewCardGrade {
  AGAIN
  HARD
  GOOD
  EASY
}

model ReviewCard {
  id             String           @id @default(uuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  sourceType     ReviewCardSource
  sourceId       String
  skillCodes     String[]
  easeFactor     Float            @default(2.5)
  interval       Int              @default(0)
  reps           Int              @default(0)
  lapses         Int              @default(0)
  dueAt          DateTime
  lastReviewedAt DateTime?
  lastGrade      ReviewCardGrade?
  isSuspended    Boolean          @default(false)
  customContent  Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  logs           ReviewLog[]

  @@unique([tenantId, userId, sourceType, sourceId])
  @@index([tenantId, userId, dueAt])
  @@index([tenantId, userId, isSuspended])
}

model ReviewLog {
  id         String          @id @default(uuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  cardId     String
  card       ReviewCard      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  grade      ReviewCardGrade
  easeFactor Float
  interval   Int
  durationMs Int?
  createdAt  DateTime        @default(now())

  @@index([tenantId, userId, createdAt])
  @@index([cardId])
}

model AiUsageQuota {
