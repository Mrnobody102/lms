generator client {
  provider = "prisma-client-js"
  output   = "../.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN // Quản trị toàn hệ thống (là bạn)
  ADMIN // Chủ trung tâm
  INSTRUCTOR // Giảng viên
  STUDENT // Học sinh
}

enum LessonType {
  video
  text
  quiz
  simulation
  micro_card
  practice
  exam
}

enum ProgressStatus {
  IN_PROGRESS
  COMPLETED
}

enum EnrollmentStatus {
  ACTIVE
  REVOKED
}

enum LearningActivityType {
  LESSON_OPENED
  LESSON_COMPLETED
  MICRO_CARD_VIEWED
  MICRO_CARD_FLIPPED
  MICRO_CARD_COMPLETED
}

enum DiscussionTargetType {
  LESSON
  PRACTICE_EXERCISE_SET
}

enum PracticeQuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  AI_EVALUATED_AUDIO
  AI_EVALUATED_TEXT
  MATCHING
  ORDERING
}

enum PracticeAttemptStatus {
  SUBMITTED
}

enum ExamQuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  AI_EVALUATED_AUDIO
  AI_EVALUATED_TEXT
  MATCHING
  ORDERING
}

enum ExamAttemptStatus {
  STARTED
  SUBMITTED
}

enum RoleplaySessionStatus {
  IN_PROGRESS
  COMPLETED
}

enum MessageRole {
  USER
  AI
  SYSTEM
}

enum MediaAssetStatus {
  UPLOADING
  READY
  FAILED
}

enum QuestionReviewStatus {
  APPROVED
  PENDING_REVIEW
  REJECTED
}

enum AiGenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AiDraftReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RoleplayMode {
  TEXT
  AUDIO
  MIXED
}

enum PronunciationAssessmentStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum RiskFlagType {
  NO_ACTIVITY
  FALLING_BEHIND
  LOW_MASTERY
  OVERDUE_SRS
  DECLINING_SCORE
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

enum MarketplaceResourceType {
  COURSE
  EXAM
  PRACTICE_EXERCISE_SET
  MEDIA_ASSET
}

enum MarketplacePricingModel {
  FREE
  MONTHLY
  ONE_TIME
}

enum ResourceSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum MarketplaceUsageEventType {
  SUBSCRIPTION_STARTED
  COURSE_PACKAGE_VIEWED
  MEDIA_SIGNED_URL
  MEDIA_STREAM_SECONDS
}

enum VideoEngagementEventType {
  PLAY
  PAUSE
  SEEK
  WATCH_SEGMENT
  COMPLETED
  ABANDONED
}

enum AdaptiveLearningPathItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum CourseActivityType {
  LESSON
  PRACTICE
  EXAM
  ROLEPLAY
}

enum CourseActivityCompletionPolicy {
  MANUAL
  LESSON_COMPLETED
  PRACTICE_SUBMITTED
  EXAM_SUBMITTED
  ROLEPLAY_COMPLETED
}

enum CourseActivityProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Tenant {
  id                               String                     @id @default(uuid())
  name                             String
  slug                             String                     @unique // Ví dụ: "trung-tam-a"
  domain                           String?                    @unique // Custom domain sau này
  settings                         Json // Lưu logo, màu sắc, config
  users                            User[]
  courses                          Course[]
  units                            CourseUnit[]
  lessons                          Lesson[]
  enrollments                      CourseEnrollment[]
  activities                       LearningActivity[]
  questions                        PracticeQuestion[]
  aiQuestionGenerationJobs         AiQuestionGenerationJob[]
  aiGeneratedQuestionDrafts        AiGeneratedQuestionDraft[]
  exerciseSets                     PracticeExerciseSet[]
  practiceAttempts                 PracticeAttempt[]
  exams                            Exam[]
  examAttempts                     ExamAttempt[]
  activationCodes                  ActivationCode[]
  redemptions                      ActivationRedemption[]
  programs                         Program[]
  levels                           Level[]
  skills                           Skill[]
  skillMasteries                   SkillMastery[]
  skillMasterySnapshots            SkillMasterySnapshot[]
  reviewCards                      ReviewCard[]
  reviewLogs                       ReviewLog[]
  aiUsageQuotas                    AiUsageQuota[]
  mediaAssets                      MediaAsset[]
  cohorts                          Cohort[]
  roleplaySessions                 RoleplaySession[]
  roleplayScenarios                RoleplayScenario[]
  pronunciationAssessments         PronunciationAssessment[]
  studentRiskSnapshots             StudentRiskSnapshot[]
  reportingRiskRules               ReportingRiskRule[]
  discussionThreads                DiscussionThread[]
  discussionReplies                DiscussionReply[]
  courseCertificates               CourseCertificate[]
  courseActivities                 CourseActivity[]
  courseActivityProgress           UserCourseActivityProgress[]
  marketplaceItems                 MarketplaceItem[]          @relation("MarketplaceItemOwnerTenant")
  marketplaceSubscriptions         ResourceSubscription[]     @relation("MarketplaceSubscriberTenant")
  marketplaceProvidedSubscriptions ResourceSubscription[]     @relation("MarketplaceProviderTenant")
  marketplaceUsageAsProvider       MarketplaceUsageEvent[]    @relation("MarketplaceUsageProviderTenant")
  marketplaceUsageAsSubscriber     MarketplaceUsageEvent[]    @relation("MarketplaceUsageSubscriberTenant")
  videoEngagementEvents            VideoEngagementEvent[]
  adaptiveLearningPathItems        AdaptiveLearningPathItem[]
  isActive                         Boolean                    @default(true)
  createdAt                        DateTime                   @default(now())
  updatedAt                        DateTime                   @default(now()) @updatedAt
  Notification                     Notification[]

  @@index([isActive])
}

model User {
  id                                String                     @id @default(uuid())
  email                             String
  password                          String
  googleSubject                     String?
  googleEmailVerified               Boolean                    @default(false)
  fullName                          String
  phoneNumber                       String?
  avatarUrl                         String?
  role                              Role                       @default(STUDENT)
  isActive                          Boolean                    @default(true)
  deletedAt                         DateTime?
  tokenVersion                      Int                        @default(0)
  passwordResetTokenHash            String?
  passwordResetExpiresAt            DateTime?
  failedLoginAttempts               Int                        @default(0)
  lockoutUntil                      DateTime?
  tenantId                          String
  tenant                            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progress                          UserLessonProgress[]
  enrollments                       CourseEnrollment[]
  activities                        LearningActivity[]
  practiceAttempts                  PracticeAttempt[]
  examAttempts                      ExamAttempt[]
  refreshTokens                     RefreshToken[]
  auditLogs                         AuditLog[]
  redemptions                       ActivationRedemption[]
  skillMasteries                    SkillMastery[]
  skillMasterySnapshots             SkillMasterySnapshot[]
  reviewCards                       ReviewCard[]
  reviewLogs                        ReviewLog[]
  aiUsageQuotas                     AiUsageQuota[]
  mediaAssets                       MediaAsset[]
  requestedAiQuestionGenerationJobs AiQuestionGenerationJob[]  @relation("AiQuestionGenerationJobRequestedBy")
  reviewedAiQuestionDrafts          AiGeneratedQuestionDraft[] @relation("AiGeneratedQuestionDraftReviewedBy")
  cohortMemberships                 CohortMembership[]
  roleplaySessions                  RoleplaySession[]
  studentRiskSnapshots              StudentRiskSnapshot[]
  discussionThreads                 DiscussionThread[]
  discussionReplies                 DiscussionReply[]
  courseCertificates                CourseCertificate[]
  courseActivityProgress            UserCourseActivityProgress[]
  videoEngagementEvents             VideoEngagementEvent[]
  adaptiveLearningPathItems         AdaptiveLearningPathItem[]
  createdAt                         DateTime                   @default(now())
  updatedAt                         DateTime                   @updatedAt
  Notification                      Notification[]
  currentStreak                     Int                        @default(0)
  longestStreak                     Int                        @default(0)
  lastActiveDate                    DateTime?

  @@unique([tenantId, email])
  @@unique([tenantId, googleSubject])
  @@unique([id, tenantId])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId  String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  action    String // e.g., 'LOGIN', 'PASSWORD_CHANGE', 'PROFILE_UPDATE'
  status    String // 'SUCCESS', 'FAILURE'
  ipAddress String?
  userAgent String?
  metadata  Json? // Any extra context
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
  @@index([action])
  @@index([createdAt])
}

model Course {
  id                        String                     @id @default(uuid())
  title                     String
  slug                      String? // SEO-friendly slug
  description               String?
  coverImageUrl             String? // URL to the course cover/thumbnail image
  isActive                  Boolean                    @default(true)
  deletedAt                 DateTime?
  tenantId                  String
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  levelId                   String?
  level                     Level?                     @relation(fields: [levelId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  units                     CourseUnit[]
  lessons                   Lesson[]
  enrollments               CourseEnrollment[]
  activities                LearningActivity[]
  questions                 PracticeQuestion[]
  aiQuestionGenerationJobs  AiQuestionGenerationJob[]
  aiGeneratedQuestionDrafts AiGeneratedQuestionDraft[]
  exerciseSets              PracticeExerciseSet[]
  practiceAttempts          PracticeAttempt[]
  exams                     Exam[]
  examAttempts              ExamAttempt[]
  roleplayScenarios         RoleplayScenario[]
  courseCertificates        CourseCertificate[]
  adaptiveLearningPathItems AdaptiveLearningPathItem[]
  courseActivities          CourseActivity[]
  totalDuration             Int                        @default(0)
  aiSettings                Json?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  activationCodes           ActivationCode[]

  @@unique([tenantId, slug])
  @@unique([id, tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
  @@index([levelId])
}

model Program {
  id          String    @id @default(uuid())
  title       String
  slug        String?
  description String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  levels      Level[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, isActive, deletedAt])
}

model Level {
  id          String    @id @default(uuid())
  title       String
  description String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programId   String
  program     Program   @relation(fields: [programId, tenantId], references: [id, tenantId], onDelete: Cascade)
  courses     Course[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, programId, deletedAt])
  @@index([programId, order])
}

model CourseUnit {
  id                        String                     @id @default(uuid())
  title                     String
  description               String?
  order                     Int                        @default(0)
  deletedAt                 DateTime?
  tenantId                  String
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId                  String
  course                    Course                     @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  lessons                   Lesson[]
  questions                 PracticeQuestion[]
  aiQuestionGenerationJobs  AiQuestionGenerationJob[]
  aiGeneratedQuestionDrafts AiGeneratedQuestionDraft[]
  exerciseSets              PracticeExerciseSet[]
  exams                     Exam[]
  roleplayScenarios         RoleplayScenario[]
  courseActivities          CourseActivity[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, courseId, deletedAt])
  @@index([courseId, order])
}

model Lesson {
  id                    String               @id @default(uuid())
  title                 String
  type                  LessonType           @default(text)
  content               String? // Nội dung bài học (HTML/Markdown)
  videoUrl              String? // Link video bài giảng
  duration              Int                  @default(10) // Thời lượng dự kiến (phút)
  aiPrompt              String?
  order                 Int                  @default(0) // Thứ tự bài học trong khóa học
  deletedAt             DateTime?
  tenantId              String
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId              String
  course                Course               @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId                String?
  unit                  CourseUnit?          @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  practiceExerciseSetId String?
  practiceExerciseSet   PracticeExerciseSet? @relation(fields: [practiceExerciseSetId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  examId                String?
  exam                  Exam?                @relation(fields: [examId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  progress              UserLessonProgress[]
  activities            LearningActivity[]
  discussions           DiscussionThread[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([id, tenantId])
  @@index([courseId])
  @@index([unitId])
  @@index([tenantId, type])
  @@index([tenantId, deletedAt])
}

model UserLessonProgress {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  lessonId  String
  lesson    Lesson         @relation(fields: [lessonId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId  String // Denormalized tenantId for row-level isolation
  status    ProgressStatus @default(IN_PROGRESS)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, lessonId])
  @@unique([id, tenantId])
  @@unique([tenantId, userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([tenantId])
}

model CourseEnrollment {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  courseId     String
  course       Course           @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now())
  unenrolledAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, courseId])
  @@unique([id, tenantId])
  @@unique([tenantId, userId, courseId])
  @@index([tenantId, status])
  @@index([courseId])
  @@index([userId])
}

model LearningActivity {
  id               String               @id @default(uuid())
  userId           String
  user             User                 @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenantId         String
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId         String
  course           Course               @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  lessonId         String
  lesson           Lesson               @relation(fields: [lessonId, tenantId], references: [id, tenantId], onDelete: Cascade)
  type             LearningActivityType
  timeSpentSeconds Int?
  occurredAt       DateTime             @default(now())

  @@index([userId, occurredAt])
  @@index([tenantId, occurredAt])
  @@index([courseId, occurredAt])
  @@index([lessonId, occurredAt])
  @@index([userId, lessonId, type, occurredAt])
}

model CourseActivity {
  id               String                         @id @default(uuid())
  tenantId         String
  tenant           Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId         String
  course           Course                         @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId           String?
  unit             CourseUnit?                    @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  type             CourseActivityType
  targetId         String
  order            Int                            @default(0)
  isRequired       Boolean                        @default(true)
  isPublished      Boolean                        @default(false)
  estimatedMinutes Int                            @default(0)
  availableFrom    DateTime?
  dueAt            DateTime?
  unlockPolicy     Json?
  completionPolicy CourseActivityCompletionPolicy @default(MANUAL)
  deletedAt        DateTime?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  progress         UserCourseActivityProgress[]

  @@unique([id, tenantId])
  @@index([tenantId, courseId, isPublished, deletedAt])
  @@index([tenantId, unitId, order])
  @@index([tenantId, type, targetId])
}

model UserCourseActivityProgress {
  id             String                       @id @default(uuid())
  tenantId       String
  tenant         Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User                         @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  activityId     String
  activity       CourseActivity               @relation(fields: [activityId, tenantId], references: [id, tenantId], onDelete: Cascade)
  status         CourseActivityProgressStatus @default(NOT_STARTED)
  completedAt    DateTime?
  lastAccessedAt DateTime?
  scorePercent   Int?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@unique([id, tenantId])
  @@unique([tenantId, userId, activityId])
  @@index([tenantId, userId, status])
  @@index([tenantId, activityId])
}

model PracticeQuestion {
  id                String                        @id @default(uuid())
  tenantId          String
  tenant            Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId          String?
  course            Course?                       @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId            String?
  unit              CourseUnit?                   @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  type              PracticeQuestionType          @default(MULTIPLE_CHOICE)
  prompt            String
  options           Json?
  correctAnswer     Json
  explanation       String?
  skillTags         String[]
  audioMediaAssetId String?
  audioMediaAsset   MediaAsset?                   @relation("PracticeQuestionAudio", fields: [audioMediaAssetId], references: [id], onDelete: SetNull)
  audioReplayLimit  Int?
  aiGenerated       Boolean                       @default(false)
  reviewStatus      QuestionReviewStatus          @default(APPROVED)
  deletedAt         DateTime?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  exerciseLinks     PracticeExerciseSetQuestion[]
  answers           PracticeAnswer[]
  approvedAiDrafts  AiGeneratedQuestionDraft[]    @relation("AiDraftApprovedQuestion")

  @@unique([id, tenantId])
  @@index([tenantId, courseId, deletedAt])
  @@index([unitId])
  @@index([type])
}

model AiQuestionGenerationJob {
  id             String                     @id @default(uuid())
  tenantId       String
  tenant         Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User                       @relation("AiQuestionGenerationJobRequestedBy", fields: [requestedById, tenantId], references: [id, tenantId], onDelete: Cascade)
  courseId       String?
  course         Course?                    @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId         String?
  unit           CourseUnit?                @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  topic          String
  context        String?
  questionType   PracticeQuestionType
  requestedCount Int
  skillTags      String[]
  status         AiGenerationJobStatus      @default(QUEUED)
  provider       String?
  model          String?
  promptVersion  String
  promptHash     String?
  sourceReason   String?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  drafts         AiGeneratedQuestionDraft[]

  @@unique([id, tenantId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, courseId, createdAt])
}

model AiGeneratedQuestionDraft {
  id                 String                  @id @default(uuid())
  tenantId           String
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobId              String
  job                AiQuestionGenerationJob @relation(fields: [jobId, tenantId], references: [id, tenantId], onDelete: Cascade)
  courseId           String?
  course             Course?                 @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId             String?
  unit               CourseUnit?             @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  type               PracticeQuestionType
  prompt             String
  options            Json?
  correctAnswer      Json
  explanation        String?
  skillTags          String[]
  difficulty         String?
  rawProviderPayload Json?
  validationIssues   Json?
  reviewStatus       AiDraftReviewStatus     @default(PENDING_REVIEW)
  reviewedById       String?
  reviewedBy         User?                   @relation("AiGeneratedQuestionDraftReviewedBy", fields: [reviewedById, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  reviewedAt         DateTime?
  rejectionReason    String?
  approvedQuestionId String?
  approvedQuestion   PracticeQuestion?       @relation("AiDraftApprovedQuestion", fields: [approvedQuestionId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, reviewStatus, createdAt])
  @@index([tenantId, jobId])
  @@index([tenantId, courseId, unitId])
}

model PracticeExerciseSet {
  id          String                        @id @default(uuid())
  tenantId    String
  tenant      Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId    String?
  course      Course?                       @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unitId      String?
  unit        CourseUnit?                   @relation(fields: [unitId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  title       String
  description String?
  isPublished Boolean                       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt
  questions   PracticeExerciseSetQuestion[]
  attempts    PracticeAttempt[]
  discussions DiscussionThread[]
  lessons     Lesson[]

  @@unique([id, tenantId])
  @@index([tenantId, courseId, isPublished, deletedAt])
  @@index([unitId])
}

model DiscussionThread {
  id            String               @id @default(uuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId      String
  author        User                 @relation(fields: [authorId, tenantId], references: [id, tenantId], onDelete: Cascade)
  targetType    DiscussionTargetType
  lessonId      String?
  lesson        Lesson?              @relation(fields: [lessonId, tenantId], references: [id, tenantId], onDelete: Cascade)
  exerciseSetId String?
  exerciseSet   PracticeExerciseSet? @relation(fields: [exerciseSetId, tenantId], references: [id, tenantId], onDelete: Cascade)
  title         String?
  content       String
  isResolved    Boolean              @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  replies       DiscussionReply[]

  @@unique([id, tenantId])
  @@index([tenantId, targetType, lessonId, createdAt])
  @@index([tenantId, targetType, exerciseSetId, createdAt])
  @@index([tenantId, authorId, createdAt])
}

model DiscussionReply {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threadId  String
  thread    DiscussionThread @relation(fields: [threadId, tenantId], references: [id, tenantId], onDelete: Cascade)
  authorId  String
  author    User             @relation(fields: [authorId, tenantId], references: [id, tenantId], onDelete: Cascade)
  content   String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, authorId, createdAt])
}

model PracticeExerciseSetQuestion {
  id            String              @id @default(uuid())
  tenantId      String
  exerciseSetId String
