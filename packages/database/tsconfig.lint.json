{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": ".",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": false
  },
  "include": ["src/**/*.ts", "prisma/*.ts", ".eslintrc.js"],
  "exclude": ["node_modules"]
}
