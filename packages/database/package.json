{
  "name": "@repo/database",
  "type": "commonjs",
  "version": "0.0.0",
  "private": true,
  "main": ".prisma/client/index.js",
  "types": ".prisma/client/index.d.ts",
  "scripts": {
    "db:push": "dotenv -e ../../.env -- node scripts/guard-db-push.cjs && dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "generate": "prisma generate",
    "build": "prisma generate && tsc --outDir dist",
    "typecheck": "tsc --noEmit",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:status": "dotenv -e ../../.env -- prisma migrate status",
    "db:resolve": "dotenv -e ../../.env -- prisma migrate resolve",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "seed": "dotenv -e ../../.env -- prisma db seed",
    "lint": "node -e \"process.exit(0)\""
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.0.9",
    "dotenv-cli": "^11.0.0",
    "prisma": "6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@prisma/client": "6.1.0",
    "bcrypt": "^6.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
