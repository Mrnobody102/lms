{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "generate": "prisma generate",
    "build": "pnpm generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^25.0.9",
    "dotenv-cli": "^11.0.0",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "latest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
