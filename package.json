{
  "name": "lms-platform",
  "private": true,
  "scripts": {
    "ports:free": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-project-processes.ps1",
    "build": "turbo run build --concurrency=1 --filter=api-server --filter=web-admin --filter=web-student --filter=super-portal --filter=@repo/database",
    "build:stable": "pnpm run ports:free && turbo run build --concurrency=1 --filter=api-server --filter=web-admin --filter=web-student --filter=super-portal --filter=@repo/database",
    "typecheck": "turbo run typecheck",
    "build:verify": "pnpm run typecheck && pnpm test && pnpm lint && pnpm run build:stable",
    "smoke:api": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-api.ps1",
    "smoke:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-deploy.ps1",
    "docker:prod:build": "powershell -ExecutionPolicy Bypass -File ./scripts/build-prod-images.ps1",
    "release:check": "pnpm run build:verify && pnpm run smoke:api && pnpm test:e2e",
    "dev": "turbo run dev --filter=api-server --filter=web-admin --filter=web-student --filter=super-portal",
    "dev:all": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "playwright:install:chromium": "pnpm --filter web-student exec playwright install --with-deps chromium",
    "test:e2e": "pnpm --filter @repo/shared build && pnpm --filter @repo/api-client build && pnpm run ports:free && pnpm --filter web-student test:e2e && pnpm --filter web-admin test:e2e && pnpm --filter super-portal test:e2e",
    "test:e2e:all": "pnpm --filter @repo/shared build && pnpm --filter @repo/api-client build && pnpm run ports:free && pnpm --filter web-student test:e2e:all && pnpm --filter web-admin test:e2e:all && pnpm --filter super-portal test:e2e:all",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:push": "pnpm --filter @repo/database run db:push",
    "db:deploy": "pnpm --filter @repo/database run db:deploy",
    "db:status": "pnpm --filter @repo/database run db:status",
    "db:resolve": "pnpm --filter @repo/database run db:resolve",
    "db:migrate": "pnpm --filter @repo/database run db:migrate",
    "db:seed": "pnpm --filter @repo/database run seed",
    "db:studio": "pnpm --filter @repo/database run db:studio"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "9.39.2",
    "@nestjs/testing": "11.1.19",
    "@repo/eslint-config": "workspace:^",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "4.0.17",
    "@vitest/spy": "4.0.17",
    "eslint": "9.39.2",
    "eslint-plugin-nestjs": "^1.2.3",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.0",
    "supertest": "^7.2.2",
    "turbo": "2.7.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "4.0.17"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13",
      "@modelcontextprotocol/sdk>ajv": "8.18.0",
      "follow-redirects": "1.16.0",
      "hono": "4.12.14",
      "path-to-regexp": "8.4.2",
      "postcss": "8.5.12",
      "qs": "6.14.2"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
