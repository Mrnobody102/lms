{
  "name": "lms-platform",
  "private": true,
  "scripts": {
    "ports:free": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-project-processes.ps1",
    "build": "turbo run build --filter=api-server --filter=web-admin --filter=web-student --filter=super-portal --filter=@repo/database",
    "build:stable": "pnpm run ports:free && turbo run build --concurrency=1 --filter=api-server --filter=web-admin --filter=web-student --filter=super-portal --filter=@repo/database",
    "build:verify": "pnpm test && pnpm lint && pnpm run build:stable",
    "smoke:api": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-api.ps1",
    "release:check": "pnpm run build:verify && pnpm run smoke:api && pnpm test:e2e",
    "dev": "turbo run dev --filter=api-server --filter=web-admin --filter=web-student --filter=super-portal",
    "dev:all": "turbo run dev",
    "lint": "turbo run lint",
    "test": "pnpm --filter api-server test && pnpm --filter @repo/shared test",
    "test:e2e": "pnpm run ports:free && pnpm --filter web-student test:e2e",
    "test:e2e:all": "pnpm run ports:free && pnpm --filter web-student test:e2e:all",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:push": "pnpm --filter @repo/database run db:push",
    "db:deploy": "pnpm --filter @repo/database run db:deploy",
    "db:status": "pnpm --filter @repo/database run db:status",
    "db:resolve": "pnpm --filter @repo/database run db:resolve",
    "db:migrate": "pnpm --filter @repo/database run db:migrate",
    "db:seed": "pnpm --filter @repo/database run seed",
    "db:studio": "pnpm --filter @repo/database run db:studio"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@nestjs/testing": "^11.1.16",
    "@repo/eslint-config": "workspace:^",
    "@types/express": "^4.17.17",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/spy": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "latest",
    "supertest": "^7.2.2",
    "turbo": "latest",
    "typescript": "latest",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.17"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
